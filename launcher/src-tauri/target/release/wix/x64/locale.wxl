<WixLocalization Culture="en-us" xmlns="http://schemas.microsoft.com/wix/2006/localization"><String Id="TauriLanguage">1033</String><String Id="TauriCodepage">1252</String><String Id="LaunchApp">Launch MuVoid Launcher</String><String Id="DowngradeErrorMessage">A newer version of MuVoid Launcher is already installed.</String><String Id="PathEnvVarFeature">Add the install location of the MuVoid Launcher executable to the PATH system environment variable. This allows the MuVoid Launcher executable to be called from any location.</String><String Id="InstallAppFeature">Installs MuVoid Launcher.</String></WixLocalization>